{
  "expo": {
    "name": "Ecoparking_App",
    "slug": "Ecoparking_App",
    "version": "1.0.1", // 🚨 ACTUALIZADO PARA LA PRÓXIMA COMPILACIÓN
    "orientation": "portrait",
    "icon": "./assets/images/logo_app.png",
    "scheme": "ecoparkingapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo_app.png",
        "backgroundImage": "./assets/images/logo_app.png",
        "monochromeImage": "./assets/images/logo_app.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jonathan_ssj.Ecoparking_App",
      // AGREGAR versionCODE AQUÍ PARA EL BUILD
      "versionCode": 2 
      // ELIMINAMOS EL ARRAY "permissions" COMPLETO
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo_app.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_app.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Permitir que Ecoparking acceda a tus fotos.",
          "savePhotosPermission": "Permitir que Ecoparking guarde códigos QR."
          // El plugin maneja los permisos necesarios (Fotos/Videos)
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "187c0fa4-2030-42aa-a3b6-a176126f0116"
      }
    }
  }
}